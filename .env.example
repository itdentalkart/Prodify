# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local MongoDB (default)
MONGODB_URI=mongodb://localhost:27017/dk_productivity

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random secret in production!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_dk2024
JWT_EXPIRES_IN=7d

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
# Your React frontend URL
FRONTEND_URL=http://192.168.1.100:5173

# ─── File Storage ────────────────────────────────────────────────────────────
SCREENSHOTS_DIR=./uploads/screenshots
MAX_SCREENSHOT_SIZE_MB=10

# ─── Server Public URL (used in agent config) ────────────────────────────────
# This is what the Windows agent will connect to
SERVER_PUBLIC_URL=http://192.168.1.100:3000
